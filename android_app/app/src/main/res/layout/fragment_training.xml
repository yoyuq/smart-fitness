<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/training_bg">

    <!-- 主区域: ESP32 全屏画面 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/esp32_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="ESP32 live preview"
            android:background="#000000" />

        <!-- 等待画面占位文字 -->
        <TextView
            android:id="@+id/esp32_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Connecting to ESP32..."
            android:textColor="#88FFFFFF"
            android:textSize="16sp" />
    </FrameLayout>

    <!-- 顶部状态卡 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#CC1B1B1F">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical">

            <View
                android:id="@+id/status_dot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/dot_offline"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/status_disconnected"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/training_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#FFFFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 中部大数字 HUD (reps + score) -->
    <LinearLayout
        android:id="@+id/hud_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="100dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="24dp">

            <TextView
                android:id="@+id/hud_reps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFFFF"
                android:textSize="84sp"
                android:textStyle="bold"
                android:shadowColor="#000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="8" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REPS"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:letterSpacing="0.3" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/hud_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FF66E0A3"
                android:textSize="84sp"
                android:textStyle="bold"
                android:shadowColor="#000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="8" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FORM"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:letterSpacing="0.3" />
        </LinearLayout>
    </LinearLayout>

    <!-- 底部 教练提示条 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/coach_tip_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="100dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#CC1B1B1F"
        android:visibility="gone">

        <TextView
            android:id="@+id/coach_tip_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end" />
    </com.google.android.material.card.MaterialCardView>

    <!-- 底部控制条 (运动选择 + 主按钮) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="12dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#F21B1B1F">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp"
            android:gravity="center_vertical">

            <Spinner
                android:id="@+id/spinner_exercise"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="#33FFFFFF"
                android:popupBackground="#FF2A2A2E" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_training_toggle"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:minWidth="120dp"
                android:text="Start"
                android:textColor="#FFFFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="28dp"
                app:backgroundTint="#FF22C55E" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 设置按钮 (浮层右上) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_settings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|top"
        android:layout_marginTop="80dp"
        android:layout_marginEnd="12dp"
        android:contentDescription="Settings"
        android:src="@android:drawable/ic_menu_preferences"
        app:fabSize="mini"
        app:backgroundTint="#CC1B1B1F"
        app:tint="#FFFFFFFF" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
